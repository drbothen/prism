// prism-infusion-plugin.wit — Infusion plugin WIT interface (S-1.15 / AD-019)
//
// An infusion plugin enriches individual values or batches of values with
// additional context (e.g., threat intel lookups, geo-IP resolution).
//
// Required exports (validated by discovery::validate_wit_interface):
//   - name()          → string          : plugin_id (must be non-empty)
//   - version()       → string          : semver string
//   - enrich-single() → enrichment      : enrich a single value
//   - enrich-batch()  → list<enrichment>: enrich a batch of values

package prism:infusion-plugin@0.1.0;

/// Log level enum shared across all Prism plugin WIT interfaces.
enum log-level {
    trace,
    debug,
    info,
    warn,
    error,
}

/// HTTP response returned to plugins by host::http-request.
record http-response {
    status: u16,
    headers: list<tuple<string, string>>,
    body: list<u8>,
}

/// The result of enriching a single value. None if no enrichment data found.
type enrichment = option<string>; // JSON-encoded enrichment object or null

/// The host interface available to all Prism plugins.
interface host {
    http-request: func(
        method: string,
        url: string,
        headers: list<tuple<string, string>>,
        body: option<list<u8>>,
    ) -> http-response;

    log: func(level: log-level, message: string);
    get-config: func(key: string) -> option<string>;
    kv-get: func(key: string) -> option<string>;
    kv-set: func(key: string, value: string) -> result<_, string>;
}

/// The infusion plugin world. Plugins compile against this world.
world infusion-plugin {
    import host;

    export name: func() -> string;
    export version: func() -> string;

    /// Enrich a single value. Returns JSON-encoded enrichment data or none.
    export enrich-single: func(
        input-value: string,
        input-type: string,
    ) -> enrichment;

    /// Enrich a batch of values. Returns one enrichment per input (in order).
    export enrich-batch: func(
        inputs: list<string>,
        input-type: string,
    ) -> list<enrichment>;
}
