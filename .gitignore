# Cloned reference repos (brownfield ingest sources)
# Exception: .references/schemas/ is tracked (S-3.7.00 derivation outputs)
.references/*
!.references/schemas
.references/schemas/*
!.references/schemas/armis
!.references/schemas/crowdstrike
.references/schemas/armis/*
!.references/schemas/armis/*.rs
!.references/schemas/armis/*.md
.references/schemas/crowdstrike/*
!.references/schemas/crowdstrike/*.rs
!.references/schemas/crowdstrike/*.md

# Factory artifacts live on factory-artifacts branch, not main
.factory/

# Claude Code local settings (use `git add -f .claude/settings.json` to share team settings)
.claude/

# MCP server config — contains API keys, must not be committed
.mcp.json

# Rust build artifacts
target/

# Fuzz testing outputs (generated by cargo fuzz / devops smoke runs)
# These are large and environment-specific — not committed.
fuzz/corpus/
fuzz/artifacts/
fuzz/Cargo.lock

# Perimeter compile-fail test crate — standalone workspace, lock file generated locally.
# The crate itself (Cargo.toml + src/) is tracked; only the generated lock is excluded.
tests/external/perimeter-violation/Cargo.lock
